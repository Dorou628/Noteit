<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.noteit.auth.repository.AuthUserMapper">

    <resultMap id="AuthUserResultMap" type="com.example.noteit.auth.model.AuthUserDO">
        <constructor>
            <idArg column="id" javaType="_long"/>
            <arg column="user_id" javaType="_long"/>
            <arg column="username" javaType="string"/>
            <arg column="password_plain_text" javaType="string"/>
            <arg column="status" javaType="_int"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="findByUsername" resultMap="AuthUserResultMap">
        SELECT id, user_id, username, password_plain_text, status, created_at, updated_at
        FROM auth_user
        WHERE username = #{username}
    </select>
</mapper>
